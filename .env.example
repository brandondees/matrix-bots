# DigitalOcean Droplet
DROPLET_IP=your.droplet.ip.here

# Path to the SSH private key you added to the droplet
SSH_KEY=~/.ssh/id_ed25519

# Non-root user to create on the droplet for running services
DROPLET_USER=matrix

# Your root domain (e.g. example.com)
DOMAIN=yourdomain.com

# Subdomain for the Matrix homeserver
# Results in: matrix.yourdomain.com
MATRIX_SUBDOMAIN=matrix
