# Copy this to .env and fill in your values.
# .env is gitignored — never commit it.
#
# IMPORTANT: values containing shell special characters ($, !, \, etc.)
# must be wrapped in single quotes, e.g.: SECRET='p@$$word!'

# IP address of your DigitalOcean droplet
DROPLET_IP=

# SSH key to use when connecting to the droplet (path on your local machine)
DROPLET_SSH_KEY=~/.ssh/your_key_name

# The hostname for your Matrix server (the DNS A record you created)
MATRIX_SERVER_NAME=matrix.yourdomain.com

# Username for the non-root system user created on the droplet
DEPLOY_USER=matrix

# One-time registration token used to create your admin account.
# Generate with: openssl rand -hex 32
# After creating your admin account, set CONDUIT_ALLOW_REGISTRATION=false and remove this.
CONDUIT_REGISTRATION_TOKEN=changeme-replace-with-openssl-rand-hex-32

# Set to true only during initial admin account creation, then back to false
CONDUIT_ALLOW_REGISTRATION=false

# Password for the OpenFang bot Matrix account (@openfang-bot:matrix.yourdomain.com)
# Generate with: openssl rand -hex 24
OPENFANG_BOT_PASSWORD=

# Access token for the OpenFang bot — obtained by logging in as openfang-bot
# via 05-create-bot-user.sh or a manual login curl. Treat like a password.
OPENFANG_BOT_ACCESS_TOKEN=
